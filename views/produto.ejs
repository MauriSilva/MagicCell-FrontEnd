      true
    );


    } catch (error) {
      mostrarMensagemCarrinho(
      error.message || "Erro ao adicionar produto.",
      false
    );
    }
  }

  function mostrarMensagemCarrinho(mensagem, sucesso) {

  const toast = document.createElement("div");

  toast.className = `
    fixed
    top-6
    right-6
    z-50
    px-6
    py-4
    rounded-xl
    shadow-lg
    font-semibold
    transition-all
  `;

  if (sucesso) {
  toast.classList.add("bg-[#00FF7F]", "text-black");
} else {
  toast.classList.add("bg-red-500", "text-white");
}

  toast.textContent = mensagem;

  document.body.appendChild(toast);

  setTimeout(() => {
    toast.remove();
  }, 3000);
}


  </script>

</body>
</html>
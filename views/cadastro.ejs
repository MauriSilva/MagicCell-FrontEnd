<!DOCTYPE html>
<html lang="pt-br">
  <%- include('layout/head') %>

  <body class="min-h-screen bg-[#0B0F1A] text-white flex items-center justify-center px-4">

    <div class="w-full max-w-md bg-[#111827] border border-[#00FF7F]/40 rounded-2xl shadow-lg p-8">
      <h1 class="text-3xl font-bold text-center mb-2 text-[#00FF7F]">
        Criar conta
      </h1>

      <p class="text-center text-gray-400 mb-8">
        Cadastre-se para comprar na MagicCell
      </p>

      <form id="cadastroForm" class="space-y-4">
        <input
          type="text"
          id="nome"
          required
          placeholder="Nome completo"
          class="w-full px-4 py-3 rounded-lg bg-[#0B0F1A] border border-gray-700 focus:border-[#00FF7F] outline-none"
        />

        <input
          type="email"
          id="email"
          required
          placeholder="Email"
          class="w-full px-4 py-3 rounded-lg bg-[#0B0F1A] border border-gray-700 focus:border-[#00FF7F] outline-none"
        />

        <input
          type="password"
          id="senha"
          required
          placeholder="Senha"
          class="w-full px-4 py-3 rounded-lg bg-[#0B0F1A] border border-gray-700 focus:border-[#00FF7F] outline-none"
        />

        <button
          type="submit"
          class="w-full bg-[#00FF7F] text-black font-bold py-3 rounded-lg hover:scale-[1.02] transition"
        >
          Cadastrar
        </button>
      </form>

      <p id="mensagem" class="mt-5 text-center text-sm"></p>

      <div class="mt-6 text-center">
        <a href="/login" class="text-[#00FF7F] hover:underline">
          Já tenho conta
        </a>
      </div>
    </div>

    <script>
      const API_URL = 'http://localhost:3000';

      const form = document.getElementById('cadastroForm');
      const mensagem = document.getElementById('mensagem');

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const nome = document.getElementById('nome').value;
        const email = document.getElementById('email').value;
        const senha = document.getElementById('senha').value;


        try {
          const response = await fetch(`${API_URL}/clientes`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              nome,
              email,
              senha,
            })
          });

          const data = await response.json();

          if (!response.ok) {
            mensagem.textContent = data.erro || 'Erro ao cadastrar';
            mensagem.className = 'mt-5 text-center text-sm text-red-400';
            return;
          }

          mensagem.textContent = 'Cadastro realizado com sucesso! Redirecionando...';
          mensagem.className = 'mt-5 text-center text-sm text-green-400';

          setTimeout(() => {
            window.location.href = '/login';
          }, 1000);

        } catch (error) {
          mensagem.textContent = 'Erro ao conectar com a API';
          mensagem.className = 'mt-5 text-center text-sm text-red-400';
        }
      });
    </script>

  </body>
</html>
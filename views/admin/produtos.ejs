
<script src="/js/auth.js"></script>

<script>

  if (!isAdmin()) {

    window.location.href = "/";

  }

</script>

<!DOCTYPE html>
<html lang="pt-BR">

<%- include('../layout/head') %>

<body class="bg-[#0B0F1A] text-white min-h-screen overflow-x-hidden">

<%- include('../layout/header') %>

<main class="max-w-7xl mx-auto px-6 py-10">

    <div class="flex justify-between items-center mb-8">

        <div>
            <h1 class="text-4xl font-bold text-[#00FF7F]">
                Gerenciar Produtos
            </h1>

            <p class="text-gray-400 mt-2">
                Adicione, edite e remova produtos do catálogo.
            </p>
        </div>

        <button
            id="novoProdutoBtn"
            class="
                bg-[#00FF7F]
                text-black
                font-bold
                px-6
                py-3
                rounded-xl
                hover:scale-105
                transition
            "
        >
            Novo Produto
        </button>

    </div>

    <div class="bg-[#111827] rounded-xl overflow-hidden">

        <table class="w-full">

            <thead class="bg-black/30">

                <tr>

                    <th class="text-left p-4">ID</th>
                    <th class="text-left p-4">Produto</th>
                    <th class="text-left p-4">Preço</th>
                    <th class="text-left p-4">Estoque</th>
                    <th class="text-left p-4">Tipo</th>
                    <th class="text-left p-4">Ações</th>

                </tr>

            </thead>

            <tbody id="produtos-container">

                <tr>
                    <td colspan="6" class="p-8 text-center text-gray-400">
                        Carregando produtos...
                    </td>
                </tr>

            </tbody>

        </table>

    </div>

</main>

<!-- Modal -->

<div
    id="produtoModal"
    class="
        hidden
        fixed
        inset-0
        bg-black/70
        flex
        items-center
        justify-center
        z-50
    "
>

    <div
        class="
            bg-[#111827]
            rounded-xl
            p-8
            w-full
            max-w-2xl
            mx-4
        "
    >

        <h2
            id="modalTitulo"
            class="text-2xl font-bold text-[#00FF7F] mb-6"
        >
            Novo Produto
        </h2>

        <form id="produtoForm" class="space-y-4">

            <input type="hidden" id="produtoId">

            <div>
                <label>Nome</label>

                <input
                    id="nome"
                    required
                    class="w-full mt-1 p-3 rounded-lg bg-[#0B0F1A] border border-gray-700"
                >
            </div>

            <div>
                <label>Descrição</label>

                <textarea
                    id="descricao"
                    required
                    rows="4"
                    class="w-full mt-1 p-3 rounded-lg bg-[#0B0F1A] border border-gray-700"
                ></textarea>
            </div>

            <div class="grid md:grid-cols-2 gap-4">

                <div>
                    <label>Preço</label>

                    <input
                        id="preco"
                        type="number"
                        step="0.01"
                        required
                        class="w-full mt-1 p-3 rounded-lg bg-[#0B0F1A] border border-gray-700"
                    >
                </div>

                <div>
                    <label>Estoque</label>

                    <input
                        id="estoque"
                        type="number"
                        required
                        class="w-full mt-1 p-3 rounded-lg bg-[#0B0F1A] border border-gray-700"
                    >
                </div>

            </div>

            <div>
                <label>Imagem URL</label>

                <input
                    id="imagem_url"
                    required
                    class="w-full mt-1 p-3 rounded-lg bg-[#0B0F1A] border border-gray-700"
                >
            </div>

            <div>
                <label>Tipo</label>

                <input
                    id="tipo"
                    required
                    class="w-full mt-1 p-3 rounded-lg bg-[#0B0F1A] border border-gray-700"
                >
            </div>

            <div class="flex justify-end gap-4 pt-4">

                <button
                    type="button"
                    onclick="fecharModal()"
                    class="
                        px-5
                        py-2
                        rounded-lg
                        border
                        border-gray-600
                    "
                >
                    Cancelar
                </button>

                <button
                    type="submit"
                    class="
                        bg-[#00FF7F]
                        text-black
                        font-bold
                        px-5
                        py-2
                        rounded-lg
                    "
                >
                    Salvar
                </button>

            </div>

        </form>

    </div>

</div>

<script src="/js/apiConfig.js"></script>

<script>

const container =
    document.getElementById("produtos-container");

const modal =
    document.getElementById("produtoModal");

const form =
    document.getElementById("produtoForm");

document
    .getElementById("novoProdutoBtn")
    .addEventListener("click", abrirNovoProduto);

async function carregarProdutos() {

    try {

        const response =
            await fetch(`${API_URL}/produtos`);

        const data =
            await response.json();

        const produtos = data.data || data;

        renderizarProdutos(produtos);

    } catch {

        container.innerHTML = `
            <tr>
                <td colspan="6" class="p-8 text-center text-red-400">
                    Erro ao carregar produtos
                </td>
            </tr>
        `;
    }
}

function renderizarProdutos(produtos) {

    container.innerHTML =
        produtos.map(produto => `

            <tr class="border-t border-gray-700">

                <td class="p-4">
                    ${produto.id_produto}
                </td>

                <td class="p-4 flex items-center gap-4">

                    <img
                        src="${produto.imagem_url}"
                        class="w-12 h-12 rounded-lg object-cover"
                    >

                    <span>
                        ${produto.nome}
                    </span>

                </td>

                <td class="p-4">
                    R$ ${Number(produto.preco).toFixed(2)}
                </td>

                <td class="p-4">
                    ${produto.estoque}
                </td>

                <td class="p-4">
                    ${produto.tipo}
                </td>

                <td class="p-4">

                    <div class="flex gap-2">

                        <button
                            onclick='editarProduto(${JSON.stringify(produto)})'
                            class="
                                bg-blue-600
                                px-3
                                py-1
                                rounded
                            "
                        >
                            Editar
                        </button>

                        <button
                            onclick="excluirProduto(${produto.id_produto})"
                            class="
                                bg-red-600
                                px-3
                                py-1
                                rounded
                            "
                        >
                            Excluir
                        </button>

                    </div>

                </td>

            </tr>

        `).join('');
}

function abrirNovoProduto() {

    form.reset();

    document.getElementById("produtoId").value = "";

    document.getElementById("modalTitulo")
        .innerText = "Novo Produto";

    modal.classList.remove("hidden");
}

function editarProduto(produto) {

    document.getElementById("modalTitulo")
        .innerText = "Editar Produto";

    document.getElementById("produtoId")
        .value = produto.id_produto;

    document.getElementById("nome")
        .value = produto.nome;

    document.getElementById("descricao")
        .value = produto.descricao;

    document.getElementById("preco")
        .value = produto.preco;

    document.getElementById("estoque")
        .value = produto.estoque;

    document.getElementById("imagem_url")
        .value = produto.imagem_url;

    document.getElementById("tipo")
        .value = produto.tipo;

    modal.classList.remove("hidden");
}

function fecharModal() {
    modal.classList.add("hidden");
}

form.addEventListener("submit", salvarProduto);

async function salvarProduto(e) {

    e.preventDefault();

    const id =
        document.getElementById("produtoId").value;

    const body = {

        nome:
            document.getElementById("nome").value,

        descricao:
            document.getElementById("descricao").value,

        preco:
            Number(
                document.getElementById("preco").value
            ),

        estoque:
            Number(
                document.getElementById("estoque").value
            ),

        imagem_url:
            document.getElementById("imagem_url").value,

        tipo:
            document.getElementById("tipo").value
    };

    const url =
        id
        ? `${API_URL}/produtos/${id}`
        : `${API_URL}/produtos`;

    const metodo =
        id
        ? "PUT"
        : "POST";

    try {

        const response = await fetch(url, {

            method: metodo,

            headers: {
                 "Content-Type": "application/json",
                Authorization: `Bearer ${getToken()}`
                    },

            body: JSON.stringify(body)
        });

        const resultado =
            await response.json();

        console.log(resultado);

        if (!response.ok) {

            throw new Error(
                resultado.erro ||
                resultado.message ||
                "Erro ao salvar"
            );
        }

        fecharModal();

        carregarProdutos();

    } catch (error) {

        console.error(error);

        alert(error.message);
    }
}

async function excluirProduto(id) {

    if (!confirm("Deseja excluir este produto?")) {
        return;
    }

    try {

        await fetch(
            `${API_URL}/produtos/${id}`,
            {
                method: "DELETE",
                 headers: {
                 "Content-Type": "application/json",
                Authorization: `Bearer ${getToken()}`
                    }
            }
        );

        carregarProdutos();

    } catch {

        alert("Erro ao excluir produto");
    }
}

carregarProdutos();

</script>

</body>
</html>
<!DOCTYPE html>
<html lang="pt-BR">

<%- include('../layout/head') %>

<body class="bg-[#0B0F1A] text-white min-h-screen overflow-x-hidden">

<%- include('../layout/header') %>

<main class="max-w-7xl mx-auto px-6 py-10">

    <div class="mb-8">

        <h1 class="text-4xl font-bold text-[#00FF7F]">
            Gerenciar Pedidos
        </h1>

        <p class="text-gray-400 mt-2">
            Visualize pedidos e atualize seus status.
        </p>

    </div>

    <div
        id="pedidos-container"
        class="space-y-6"
    >

        <div
            class="
                bg-[#111827]
                rounded-xl
                p-8
                text-center
                text-gray-400
            "
        >
            Carregando pedidos...
        </div>

    </div>

</main>

<script src="/js/apiConfig.js"></script>
<script src="/js/auth.js"></script>

<script>

if (!isAdmin()) {
    window.location.href = "/";
}

const container =
    document.getElementById(
        "pedidos-container"
    );

async function carregarPedidos() {

    try {

        const response = await fetch(
            `${API_URL}/pedidos/admin/todos`,
            {
                headers: {
                    Authorization:
                        `Bearer ${getToken()}`
                }
            },
            
        );

        const data =
            await response.json();

        const pedidos =
            data.data || data;
        renderizarPedidos(pedidos);
        

    } catch (error) {

        console.error(error);

        container.innerHTML = `
            <div
                class="
                    bg-[#111827]
                    rounded-xl
                    p-8
                    text-center
                    text-red-400
                "
            >
                Erro ao carregar pedidos.
            </div>
        `;
    }
}

function renderizarPedidos(pedidos) {

    if (!pedidos.length) {

        container.innerHTML = `
            <div
                class="
                    bg-[#111827]
                    rounded-xl
                    p-8
                    text-center
                    text-gray-400
                "
            >
                Nenhum pedido encontrado.
            </div>
        `;

        return;
    }

    container.innerHTML =
        pedidos.map(pedido => `

            <div
                class="
                    bg-[#111827]
                    rounded-xl
                    border
                    border-[#00FF7F]/20
                    p-6
                "
            >

                <div
                    class="
                        flex
                        flex-wrap
                        justify-between
                        gap-6
                    "
                >

                    <div>

                        <h2
                            class="
                                text-2xl
                                font-bold
                                text-[#00FF7F]
                            "
                        >
                            Pedido #${pedido.id_pedido}
                        </h2>

                        <p class="text-gray-400 mt-1">
                            Cliente ${pedido.nome}
                        </p>

                        <p class="text-gray-400 mt-1">
                            Id #${pedido.id_cliente}
                        </p>

                        <p class="text-gray-400">
                           Data do pedido: ${new Date(
                                pedido.criado_em
                            ).toLocaleDateString(
                                "pt-BR"
                            )}
                        </p>

                    </div>

                    <div
                        class="
                            text-right
                        "
                    >

                        <p
                            class="
                                text-3xl
                                font-bold
                            "
                        >
                            R$ ${Number(
                                pedido.total
                            ).toLocaleString(
                                "pt-BR",
                                {
                                    minimumFractionDigits: 2
                                }
                            )}
                        </p>

                    </div>

                </div>

                <div
                    class="
                        mt-6
                        flex
                        flex-wrap
                        gap-4
                        items-center
                    "
                >

                    <select
                        onchange="
                            atualizarStatus(
                                ${pedido.id_pedido},
                                this.value
                            )
                        "
                        class="
                            bg-[#0B0F1A]
                            border
                            border-[#00FF7F]/20
                            rounded-lg
                            px-4
                            py-2
                        "
                    >

                        <option
                            value="pendente"
                            ${pedido.status === 'pendente'
                                ? 'selected'
                                : ''}
                        >
                            Pendente
                        </option>

                        <option
                            value="pago"
                            ${pedido.status === 'pago'
                                ? 'selected'
                                : ''}
                        >
                            Pago
                        </option>

                        <option
                            value="enviado"
                            ${pedido.status === 'enviado'
                                ? 'selected'
                                : ''}
                        >
                            Enviado
                        </option>

                        <option
                            value="entregue"
                            ${pedido.status === 'entregue'
                                ? 'selected'
                                : ''}
                        >
                            Entregue
                        </option>

                        <option
                            value="cancelado"
                            ${pedido.status === 'cancelado'
                                ? 'selected'
                                : ''}
                        >
                            Cancelado
                        </option>

                    </select>

                    <button
                        onclick="
                            carregarDetalhes(
                                ${pedido.id_pedido}
                            )
                        "
                        class="
                            bg-[#00FF7F]
                            text-black
                            font-bold
                            px-5
                            py-2
                            rounded-lg
                            hover:scale-105
                            transition
                        "
                    >
                        Ver Itens
                    </button>

                </div>

                <div
                    id="detalhes-${pedido.id_pedido}"
                    class="mt-4"
                ></div>

            </div>

        `).join('');
}

async function carregarDetalhes(idPedido) {

    const detalhesDiv =
        document.getElementById(
            `detalhes-${idPedido}`
        );

    if (detalhesDiv.innerHTML.trim()) {

        detalhesDiv.innerHTML = '';
        return;
    }

    try {

        const response = await fetch(
            `${API_URL}/pedidos/admin/${idPedido}`,
            {
                headers: {
                    Authorization:
                        `Bearer ${getToken()}`
                }
            }
        );

        const itens =
            await response.json();

        detalhesDiv.innerHTML = `

            <div
                class="
                    mt-4
                    border-t
                    border-gray-700
                    pt-4
                "
            >

                <h3
                    class="
                        font-bold
                        mb-3
                        text-[#00FF7F]
                    "
                >
                    Itens do Pedido
                </h3>

                ${itens.map(item => `

                    <div
                        class="
                            flex
                            justify-between
                            py-2
                            border-b
                            border-gray-800
                        "
                    >

                        <div>

                            <p class="font-semibold">
                                ${item.nome}
                            </p>

                            <p
                                class="
                                    text-sm
                                    text-gray-400
                                "
                            >
                                R$ ${Number(
                                    item.preco_unitario
                                ).toLocaleString(
                                    "pt-BR",
                                    {
                                        minimumFractionDigits: 2
                                    }
                                )}
                            </p>

                        </div>

                        <div>

                            ${item.quantidade}x

                        </div>

                    </div>

                `).join('')}

            </div>

        `;

    } catch (error) {

        console.error(error);

        detalhesDiv.innerHTML = `
            <div class="text-red-400">
                Erro ao carregar itens.
            </div>
        `;
    }
}

async function atualizarStatus(
    idPedido,
    novoStatus
) {

    try {

        const response = await fetch(
            `${API_URL}/pedidos/admin/${idPedido}/status`,
            {
                method: "PUT",

                headers: {
                    "Content-Type":
                        "application/json",

                    Authorization:
                        `Bearer ${getToken()}`
                },

                body: JSON.stringify({
                    status: novoStatus
                })
            }
        );

        if (!response.ok) {

            const erro =
                await response.json();

            throw new Error(
                erro.erro ||
                "Erro ao atualizar status"
            );
        }

    } catch (error) {

        console.error(error);

        alert(error.message);
    }
}

carregarPedidos();

</script>

</body>
</html>
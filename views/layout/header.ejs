<!-- Overlay escuro -->
<div id="overlay" class="hidden fixed inset-0 bg-black/50 md:hidden z-40"></div>

<script>
  const toggle = document.getElementById("toggle");
  const mobileMenu = document.getElementById("mobileMenu");
  const overlay = document.getElementById("overlay");

  toggle.addEventListener("click", () => {
    mobileMenu.classList.toggle("translate-x-full");
    overlay.classList.toggle("hidden");
  });

  overlay.addEventListener("click", () => {
    mobileMenu.classList.add("translate-x-full");
    overlay.classList.add("hidden");
  });


  const toggleBtn = document.getElementById('themeToggle');
  const themeIcon = document.getElementById('themeIcon');
  const logo = document.getElementById('logo');
  const body = document.body;

  // Tema inicial
  body.classList.add('dark-theme');
  themeIcon.src = "/images/moon.png";
  logo.src = "/images/LogoAtualizada.png";


toggleBtn.addEventListener('click', () => {
  if (body.classList.contains('dark-theme')) {
    body.classList.remove('dark-theme');
    body.classList.add('light-theme');
    themeIcon.src = "/images/sun.png"; // ícone sol
    logo.src = "/images/LogoAtualizada.png"; // logo versão clara
  } else {
    body.classList.remove('light-theme');
    body.classList.add('dark-theme');
    themeIcon.src = "/images/moon.png"; // ícone lua
    logo.src = "/images/LogoAtualizada.png"; // logo versão escura
  }
});

</script>

<style>
  /* Tema escuro: ícones ficam claros */
.dark-theme #themeIcon,
.dark-theme #themeshadowgreen {
  filter: invert(100%) sepia(100%) saturate(0%) hue-rotate(0deg) brightness(200%);
}

/* Tema claro: ícones mantêm cor original */
.light-theme #themeIcon,
.light-theme #themeshadowgreen {
  filter: none;
}

</style>





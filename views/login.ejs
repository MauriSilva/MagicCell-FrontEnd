<!DOCTYPE html>
<html lang="pt-br">
  <%- include('layout/head') %>

  <body class="min-h-screen bg-[#0B0F1A] text-white flex items-center justify-center px-4">

    <div class="w-full max-w-md bg-[#111827] border border-[#00FF7F]/40 rounded-2xl shadow-lg p-8">
      <h1 class="text-3xl font-bold text-center mb-2 text-[#00FF7F]">
        Login
      </h1>

      <p class="text-center text-gray-400 mb-8">
        Entre para acessar seu carrinho
      </p>

      <form id="loginForm" class="space-y-5">
        <div>
          <label class="block mb-2 text-sm font-semibold">Email</label>
          <input
            type="email"
            id="email"
            required
            placeholder="seuemail@email.com"
            class="w-full px-4 py-3 rounded-lg bg-[#0B0F1A] border border-gray-700 focus:border-[#00FF7F] outline-none"
          />
        </div>

        <div>
          <label class="block mb-2 text-sm font-semibold">Senha</label>
          <input
            type="password"
            id="senha"
            required
            placeholder="Sua senha"
            class="w-full px-4 py-3 rounded-lg bg-[#0B0F1A] border border-gray-700 focus:border-[#00FF7F] outline-none"
          />
        </div>

        <button
          type="submit"
          class="w-full bg-[#00FF7F] text-black font-bold py-3 rounded-lg hover:scale-[1.02] transition"
        >
          Entrar
        </button>

        <button
          class="w-full bg-[#00FF7F] text-black font-bold py-3 rounded-lg hover:scale-[1.02] transition">
          <a href="/cadastro">Cadastre-se</a>
        </button>

      </form>

      <p id="mensagem" class="mt-5 text-center text-sm"></p>

      <div class="mt-6 text-center">
        <a href="/" class="text-[#00FF7F] hover:underline">
          Voltar para a loja
        </a>
      </div>
    </div>

    <script>
      const API_URL = 'http://localhost:3000';

      const form = document.getElementById('loginForm');
      const mensagem = document.getElementById('mensagem');

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const email = document.getElementById('email').value;
        const senha = document.getElementById('senha').value;

        try {
          const response = await fetch(`${API_URL}/clientes/login`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ email, senha })
          });

          const data = await response.json();

          if (!response.ok) {
            mensagem.textContent = data.erro || 'Erro ao fazer login';
            mensagem.className = 'mt-5 text-center text-sm text-red-400';
            return;
          }

          localStorage.setItem('token', data.token);
          localStorage.setItem('cliente', JSON.stringify(data.cliente));

          mensagem.textContent = 'Login realizado com sucesso!';
          mensagem.className = 'mt-5 text-center text-sm text-green-400';

          setTimeout(() => {
            window.location.href = '/';
          }, 800);

        } catch (error) {
          mensagem.textContent = 'Erro ao conectar com a API';
          mensagem.className = 'mt-5 text-center text-sm text-red-400';
        }
      });
    </script>

  </body>
</html>
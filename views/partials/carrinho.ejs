<!DOCTYPE html>
<html lang="pt-br">
  <%- include('../layout/head') %>

  <body class="overflow-x-hidden antialiased bg-gray-100">

    <div class="max-w-4xl mx-auto px-6 mt-10">
      <h2 class="text-2xl font-bold mb-6 text-black">Meu Carrinho</h2>

      <div id="mensagem" class="mb-4 text-sm font-semibold text-black"></div>

      <div id="carrinho-container" class="space-y-4"></div>

      <div class="mt-6 text-right">
        <p id="total" class="text-xl font-bold text-green-600"></p>

        <button
          id="btn-finalizar"
          class="mt-3 bg-green-500 hover:bg-green-600 text-black font-bold py-2 px-6 rounded"
        >
          Finalizar Compra
        </button>
      </div>

      <div class="mt-6">
        <a href="/" class="text-green-600 font-semibold hover:underline">
          Voltar para a loja
        </a>
      </div>
    </div>

    <script src="/js/apiConfig.js"></script>

    <script>
      const carrinhoContainer = document.getElementById('carrinho-container');
      const totalElemento = document.getElementById('total');
      const mensagem = document.getElementById('mensagem');
      const btnFinalizar = document.getElementById('btn-finalizar');

      function getToken() {
        return localStorage.getItem('token');
      }

      function formatarPreco(valor) {
        return Number(valor).toLocaleString('pt-BR', {
          style: 'currency',
          currency: 'BRL'
        });
      }

      async function carregarCarrinho() {
        const token = getToken();

        if (!token) {
          mensagem.textContent = 'Você precisa fazer login para ver o carrinho.';
          mensagem.className = 'mb-4 text-sm font-semibold text-red-600';
          carrinhoContainer.innerHTML = `
            <a href="/login" class="inline-block bg-green-500 text-black font-bold py-2 px-4 rounded">
              Ir para login
            </a>
          `;
          totalElemento.textContent = '';
          btnFinalizar.style.display = 'none';
          return;
        }

        try {
          const response = await fetch(`${API_URL}/carrinho`, {
            headers: {
              Authorization: `Bearer ${token}`
            }
          });

          const data = await response.json();

          if (!response.ok) {
            mensagem.textContent = data.erro || 'Erro ao carregar carrinho.';
            mensagem.className = 'mb-4 text-sm font-semibold text-red-600';
            return;
          }

          if (!data.itens || data.itens.length === 0) {
            carrinhoContainer.innerHTML = `
              <div class="bg-white p-5 rounded shadow text-center">
                <p class="font-semibold">Seu carrinho está vazio.</p>
              </div>
            `;
            totalElemento.textContent = 'Total: R$ 0,00';
            btnFinalizar.style.display = 'none';
            return;
          }

          mensagem.textContent = '';
          btnFinalizar.style.display = 'inline-block';

          carrinhoContainer.innerHTML = data.itens.map(item => `
            <div class="bg-white p-5 rounded shadow flex items-center justify-between gap-4">
              <div>
                <h3 class="font-bold text-lg text-black">${item.nome}</h3>
                <p class="text-gray-600">Preço: ${formatarPreco(item.preco)}</p>
                <p class="text-gray-600">Subtotal: ${formatarPreco(item.subtotal)}</p>
              </div>

              <div class="flex items-center gap-3">
                <input
                  type="number"
                  min="1"
                  value="${item.quantidade}"
                  class="w-20 border rounded px-2 py-1 text-black"
                  onchange="alterarQuantidade(${item.id_item}, this.value)"
                />

                <button
                  onclick="removerItem(${item.id_item})"
                  class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded"
                >
                  Remover
                </button>
              </div>
            </div>
          `).join('');

          totalElemento.textContent = `Total: ${formatarPreco(data.total)}`;

        } catch (error) {
          mensagem.textContent = 'Erro ao conectar com a API.';
          mensagem.className = 'mb-4 text-sm font-semibold text-red-600';
        }
      }

      async function alterarQuantidade(idItem, quantidade) {
        const token = getToken();

        try {
          const response = await fetch(`${API_URL}/carrinho/${idItem}`, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              Authorization: `Bearer ${token}`
            },
            body: JSON.stringify({
              quantidade: Number(quantidade)
            })
          });

          const data = await response.json();

          if (!response.ok) {
            alert(data.erro || 'Erro ao alterar quantidade.');
            return;
          }

          carregarCarrinho();

        } catch (error) {
          alert('Erro ao conectar com a API.');
        }
      }

      async function removerItem(idItem) {
        const token = getToken();

        try {
          const response = await fetch(`${API_URL}/carrinho/${idItem}`, {
            method: 'DELETE',
            headers: {
              Authorization: `Bearer ${token}`
            }
          });

          const data = await response.json();

          if (!response.ok) {
            alert(data.erro || 'Erro ao remover item.');
            return;
          }

          carregarCarrinho();

        } catch (error) {
          alert('Erro ao conectar com a API.');
        }
      }

      async function finalizarCompra() {
        const token = getToken();

        try {
          const response = await fetch(`${API_URL}/pedidos/finalizar-carrinho`, {
            method: 'POST',
            headers: {
              Authorization: `Bearer ${token}`
            }
          });

          const data = await response.json();

          if (!response.ok) {
            alert(data.erro || 'Erro ao finalizar compra.');
            return;
          }

          alert(`Compra finalizada! Pedido #${data.id_pedido}`);
          carregarCarrinho();

        } catch (error) {
          alert('Erro ao conectar com a API.');
        }
      }

      btnFinalizar.addEventListener('click', finalizarCompra);

      carregarCarrinho();
    </script>

  </body>
</html>
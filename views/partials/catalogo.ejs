
<div class="flex flex-wrap justify-center gap-6 mb-10 text-green-500">

  <button onclick="filtrarProdutos('smartphones')" class="font-bold hover:text-green-300"> 
     <div class="category-icon smartphone-icon"></div> Celulares
  </button>

  <button onclick="filtrarProdutos('perifericos')" class="font-bold hover:text-green-300">
    <div class="category-icon tablet-icon"></div> Periféricos
  </button>

  <button onclick="filtrarProdutos('fones')" class="font-bold hover:text-green-300">
    <div class="category-icon FonesdeOuvido-icon"></div> Fones de Ouvido
  </button>

  <button onclick="filtrarProdutos('componentes')" class="font-bold hover:text-green-300">
    <div class="category-icon desktop-icon"></div>Componentes
  </button>

  <button onclick="filtrarProdutos('luminarias')" class="font-bold hover:text-green-300">
    <div class="category-icon Luminarias-icon"></div> Luminárias
  </button>

  <button onclick="filtrarProdutos('acessorios')" class="font-bold hover:text-green-300">
     <div class="category-icon accessories-icon "></div> Acessórios
  </button>

</div>

<section class="max-w-7xl mx-auto px-6 mt-10 mb-10">

  <h2 class="text-2xl font-bold mb-8">Produtos</h2>

  <div
    id="produtos-container"
    class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6"
  ></div>

</section>

<script>
  const API_URL = 'https://api-magiccell.onrender.com';
  const container = document.getElementById("produtos-container");

  let produtosGlobais = [];

  function formatarPreco(valor) {
    return Number(valor).toLocaleString("pt-BR", {
      style: "currency",
      currency: "BRL"
    });
  }

  function getToken() {
    return localStorage.getItem("token");
  }

  async function carregarProdutos() {
    try {
      const response = await fetch(`${API_URL}/produtos`);
      const produtos = await response.json();

      if (!response.ok) {
        container.innerHTML = "<p class='text-white'>Erro ao carregar produtos.</p>";
        return;
      }

      produtosGlobais = produtos;
      renderizarProdutos(produtosGlobais);

    } catch (error) {
      container.innerHTML = "<p class='text-white'>Erro ao conectar com a API.</p>";
    }
  }

  function filtrarProdutos(tipo) {
    if (tipo === "todos") {
      renderizarProdutos(produtosGlobais);
      return;
    }

    const filtrados = produtosGlobais.filter(produto => {
      return produto.tipo === tipo;
    });

    renderizarProdutos(filtrados);
  }

  function renderizarProdutos(produtos) {
    if (!produtos || produtos.length === 0) {
      container.innerHTML = "<p class='text-white'>Nenhum produto encontrado.</p>";
      return;
    }

    container.innerHTML = produtos.map(produto => `
      <div class="border rounded-lg shadow-md p-4 bg-white text-gray-900 flex flex-col 
                transition-transform duration-300 hover:shadow-lg hover:-translate-y-1">

        <img
          src="${produto.imagem_url || '/img/produto.png'}"
          class="w-full h-40 object-contain mb-4"
          alt="${produto.nome}"
        />

        <h3 class="font-bold text-lg mb-1 text-gray-900">
          ${produto.nome}
        </h3>

        <p class="text-gray-600 text-sm flex-grow">
          ${produto.descricao || ""}
        </p>

        <p class="text-green-600 font-bold text-lg mt-3">
          ${formatarPreco(produto.preco)}
        </p>

        <p class="text-gray-500 text-xs mt-1">
          Estoque: ${produto.estoque}
        </p>

        <button
          onclick="adicionarCarrinho(${produto.id_produto})"
          class="mt-3 bg-green-500 hover:bg-green-600 text-black font-bold py-2 rounded"
        >
          Adicionar ao carrinho
        </button>

      </div>
    `).join("");
  }

  async function adicionarCarrinho(idProduto) {
    const token = getToken();

    if (!token) {
      alert("Faça login para adicionar ao carrinho.");
      window.location.href = "/login";
      return;
    }

    try {
      const response = await fetch(`${API_URL}/carrinho`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Authorization": "Bearer " + token
        },
        body: JSON.stringify({
          id_produto: idProduto,
          quantidade: 1
        })
      });

      const data = await response.json();

      if (!response.ok) {
        alert(data.erro || "Erro ao adicionar ao carrinho.");
        return;
      }

      alert("Produto adicionado ao carrinho!");

    } catch (error) {
      alert("Erro ao conectar com a API.");
    }
  }

  function pesquisarProdutos(termo) {
  const busca = termo.toLowerCase().trim();

  if (!busca) {
    renderizarProdutos(produtosGlobais);
    return;
  }

  const resultados = produtosGlobais.filter(produto => {
    const nome = produto.nome?.toLowerCase() || "";
    const descricao = produto.descricao?.toLowerCase() || "";
    const tipo = produto.tipo?.toLowerCase() || "";

    return (
      nome.includes(busca) ||
      descricao.includes(busca) ||
      tipo.includes(busca)
    );
  });

  renderizarProdutos(resultados);
}

  const buscaProdutos = document.getElementById("searchInput");

if (buscaProdutos) {
  searchInput.addEventListener("input", () => {
    pesquisarProdutos(buscaProdutos.value);
  });
}

  carregarProdutos();
</script>

